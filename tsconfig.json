{
  "compilerOptions": {
    "target": "ES2017",
    "module": "None",
    "lib": ["DOM", "DOM.Iterable", "ES2017"],
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "outDir": "./dist",
    "rootDir": "./",
    "removeComments": false,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["main.ts"],
  "exclude": ["node_modules", "dist"]
}
